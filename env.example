# ╔══════════════════════════════════════════════════════════════╗
# ║  Referência: app/core/settings.py                           ║
# ║  Variáveis marcadas com [DC] são usadas apenas pelo         ║
# ║  docker-compose.yml e não fazem parte do Settings da app.   ║
# ╚══════════════════════════════════════════════════════════════╝

# --- PostgreSQL (desenvolvimento local) ---
POSTGRES_USER=mundoinvest                # [DC]
POSTGRES_PASSWORD=mundoinvest            # [DC]
POSTGRES_DB=mundoinvest                  # [DC]
POSTGRES_PORT=5432                       # [DC]
DATABASE_URL=postgresql+asyncpg://mundoinvest:mundoinvest@localhost:5432/mundoinvest

# --- PostgreSQL (testes) ---
POSTGRES_TEST_USER=mundoinvest_test      # [DC]
POSTGRES_TEST_PASSWORD=mundoinvest_test  # [DC]
POSTGRES_TEST_DB=mundoinvest_test        # [DC]
POSTGRES_TEST_PORT=5433                  # [DC]
TEST_DATABASE_URL=postgresql+asyncpg://mundoinvest_test:mundoinvest_test@localhost:5433/mundoinvest_test

# --- Pipefy ---
PIPEFY_PIPE_ID=000000
PIPEFY_PHASE_ID=000000
PIPEFY_API_TOKEN=mock_token

# --- Aplicação ---
ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=["*"]
WORKERS=1
APPLICATION_PORT=8000
